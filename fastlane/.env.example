# Copy this file to `fastlane/.env` (gitignored) and fill in your values.
# These come from the App Store Connect API key you generate at:
#   App Store Connect → Users and Access → Integrations → App Store Connect API → Keys

# The 10-character Key ID shown next to the key in the list.
ASC_KEY_ID=XXXXXXXXXX

# The Issuer ID shown above the keys table (a UUID, shared by all your keys).
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded .p8 private key file. Keep it OUTSIDE the repo
# (e.g. ~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8). You can only
# download the .p8 once, at creation time.
ASC_KEY_FILEPATH=/Users/michael/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
